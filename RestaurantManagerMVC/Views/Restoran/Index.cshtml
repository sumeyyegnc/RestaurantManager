@model List<Restoran>
@{
    ViewData["Title"] = "Restoranlar";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Restoranlar</h2>
    <a asp-action="Create" class="btn btn-primary">+ Yeni Restoran</a>
</div>

<form asp-action="Index" method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <input type="text" name="term" value="@ViewBag.Term" class="form-control" placeholder="Ad, adres veya sehire gore ara..." />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary">Ara</button>
        <a asp-action="Index" class="btn btn-outline-dark">Temizle</a>
    </div>
    <div class="col-auto ms-auto">
        <a asp-action="ExportPdf" asp-route-term="@ViewBag.Term" class="btn btn-outline-danger">PDF</a>
        <a asp-action="ExportExcel" asp-route-term="@ViewBag.Term" class="btn btn-outline-success">Excel</a>
    </div>
</form>

<table class="table table-bordered table-hover bg-white">
    <thead>
        <tr>
            <th>Id</th>
            <th>Ad</th>
            <th>Adres</th>
            <th>Telefon</th>
            <th>Sehir</th>
            <th class="text-end">Islemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var r in Model)
        {
            <tr>
                <td>@r.Id</td>
                <td>@r.Ad</td>
                <td>@r.Adres</td>
                <td>@r.Telefon</td>
                <td>@r.Sehir</td>
                <td class="text-end">
                    <a asp-action="Details" asp-route-id="@r.Id" class="btn btn-sm btn-outline-info">Detay</a>
                    <a asp-action="Edit" asp-route-id="@r.Id" class="btn btn-sm btn-outline-warning">Duzenle</a>
                    <a asp-action="Delete" asp-route-id="@r.Id" class="btn btn-sm btn-outline-danger">Sil</a>
                </td>
            </tr>
        }
        @if (!Model.Any())
        {
            <tr><td colspan="6" class="text-center text-muted">Kayit bulunamadi.</td></tr>
        }
    </tbody>
</table>
