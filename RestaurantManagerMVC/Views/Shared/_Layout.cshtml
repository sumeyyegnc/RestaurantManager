<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Restoran Yonetim Sistemi</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" asp-controller="Restoran" asp-action="Index">🍽️ Restoran Yonetim</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Restoran" asp-action="Index">Restoranlar</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Yemek" asp-action="Index">Yemekler</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Siparis" asp-action="Index">Siparisler</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container">
        @if (TempData["Basari"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Basari"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
