@model List<Siparis>
@{ ViewData["Title"] = "Siparisler"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Siparisler</h2>
    <a asp-action="Create" class="btn btn-primary">+ Yeni Siparis</a>
</div>

<form asp-action="Index" method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <input type="text" name="term" value="@ViewBag.Term" class="form-control" placeholder="Musteri, restoran, yemek veya duruma gore ara..." />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary">Ara</button>
        <a asp-action="Index" class="btn btn-outline-dark">Temizle</a>
    </div>
    <div class="col-auto ms-auto">
        <a asp-action="ExportPdf" asp-route-term="@ViewBag.Term" class="btn btn-outline-danger">PDF</a>
        <a asp-action="ExportExcel" asp-route-term="@ViewBag.Term" class="btn btn-outline-success">Excel</a>
    </div>
</form>

<table class="table table-bordered table-hover bg-white">
    <thead>
        <tr>
            <th>Id</th>
            <th>Musteri</th>
            <th>Restoran</th>
            <th>Yemek</th>
            <th>Adet</th>
            <th>Tarih</th>
            <th>Durum</th>
            <th class="text-end">Islemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var s in Model)
        {
            <tr>
                <td>@s.Id</td>
                <td>@s.MusteriAdi</td>
                <td>@s.RestoranAdi</td>
                <td>@s.YemekAdi</td>
                <td>@s.Adet</td>
                <td>@s.Tarih.ToString("dd.MM.yyyy HH:mm")</td>
                <td><span class="badge bg-secondary">@s.Durum</span></td>
                <td class="text-end">
                    <a asp-action="Details" asp-route-id="@s.Id" class="btn btn-sm btn-outline-info">Detay</a>
                    <a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-sm btn-outline-warning">Duzenle</a>
                    <a asp-action="Delete" asp-route-id="@s.Id" class="btn btn-sm btn-outline-danger">Sil</a>
                </td>
            </tr>
        }
        @if (!Model.Any())
        {
            <tr><td colspan="8" class="text-center text-muted">Kayit bulunamadi.</td></tr>
        }
    </tbody>
</table>
