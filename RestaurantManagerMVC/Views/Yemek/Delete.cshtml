@model Yemek
@{ ViewData["Title"] = "Yemek Sil"; }

<h2>Yemek Sil</h2>

<div class="card p-4" style="max-width:600px;">
    <p class="text-danger">Bu yemegi silmek istediginize emin misiniz?</p>
    <dl class="row">
        <dt class="col-sm-3">Yemek</dt><dd class="col-sm-9">@Model.Ad</dd>
        <dt class="col-sm-3">Restoran</dt><dd class="col-sm-9">@Model.RestoranAdi</dd>
        <dt class="col-sm-3">Fiyat</dt><dd class="col-sm-9">@Model.Fiyat.ToString("N2") TL</dd>
    </dl>
    <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
        <button type="submit" class="btn btn-danger">Evet, Sil</button>
        <a asp-action="Index" class="btn btn-secondary">Vazgec</a>
    </form>
</div>
